include LICENSE
include README.md
include pyproject.toml

recursive-include src/stmtforge *.py *.yaml
recursive-include assets *.svg *.png
recursive-include images *.png *.jpg *.webp

exclude .env
exclude .env.example
exclude config.yaml
exclude credentials.json
exclude token.json
exclude pytest.ini

prune data
prune tests
prune .github
prune deploy
prune scripts
prune social_posts
